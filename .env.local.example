# Copy this file to .env.local and fill in your TMDB API key
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Optional: production site URL used for Open Graph/Twitter image resolution.
# Set this in Vercel as NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
