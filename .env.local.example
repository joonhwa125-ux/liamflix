# Copy this file to .env.local and fill in your TMDB API key
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_v3_api_key_here

# Optional: enables the "YouTube 인기 댓글" section under each trailer.
# Get one at https://console.cloud.google.com/ → APIs & Services → Credentials.
# Enable YouTube Data API v3 first. The trailer-comments section is silently
# hidden when this is missing or invalid.
YOUTUBE_API_KEY=

# Optional: production site URL used for Open Graph/Twitter image resolution.
# Set this in Vercel as NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
